# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/codementor-ai

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Local AI Engine URL
# Docker (default): http://ai-engine:8080
# Local dev: http://localhost:5000
PYTHON_AI_ENGINE_URL=http://localhost:5000

# Google Cloud / Vertex AI (for Gemini provider)
# Uses Application Default Credentials automatically when running on Cloud Run
GCP_PROJECT_ID=codementor-ai-platform
GCP_LOCATION=us-central1
# Gemini model to use (default: gemini-1.5-flash). Options: gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash
